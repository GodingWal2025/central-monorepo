{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "outputs": ["dist/**"],
      "inputs": ["src/**", "tsconfig.json", "vite.config.ts"],
      "dependsOn": ["^build"]
    },
    "test": {
      "inputs": ["src/**", "__tests__/**", "tsconfig.json"],
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig*.json"]
    },
    "deploy": {
      "dependsOn": ["build", "test"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}

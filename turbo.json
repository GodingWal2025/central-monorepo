{
  "tasks": {
    "test": {
      "outputs": ["coverage/**"],
      "cache": false
    },
    "build": {
      "outputs": ["dist/**", ".next/**"],
      "inputs": ["src/**", "tsconfig.json"],
      "dependsOn": ["^build"]
    },
    "deploy": {
      "dependsOn": ["build", "test"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
